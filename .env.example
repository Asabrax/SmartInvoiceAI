GROQ_API_KEY=your_groq_api_key
SMARTINVOICEAI_API_KEY=replace_with_a_long_random_value
SMARTINVOICEAI_MAX_UPLOAD_BYTES=10485760

OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# Local durable default:
DATABASE_URL=sqlite:///data/smart_invoice_ai.sqlite3

# MySQL option:
# DATABASE_URL=mysql+pymysql://smartinvoice:smartinvoice@localhost:3307/smartinvoice

# PostgreSQL option:
# DATABASE_URL=postgresql+psycopg://smartinvoice:smartinvoice@localhost:5432/smartinvoice

GROQ_MODELS=meta-llama/llama-4-scout-17b-16e-instruct,llama-3.3-70b-versatile,llama-3.1-8b-instant
